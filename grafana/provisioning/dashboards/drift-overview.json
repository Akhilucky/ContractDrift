{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.4.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "2.0.0" },
    { "type": "panel", "id": "table", "name": "Table", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time Series", "version": "1.0.0" },
    { "type": "panel", "id": "barchart", "name": "Bar Chart", "version": "1.0.0" }
  ],
  "title": "Contract Drift Overview",
  "editable": true,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": [],
      "title": "Drift Score Heatmap",
      "type": "row"
    },
    {
      "id": 2,
      "title": "Drift Score Gauge",
      "type": "table",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 1 },
      "options": {
        "cellHeight": "sm",
        "footer": { "show": false },
        "showTypeIcons": true,
        "sortBy": [{ "displayName": "Drift Score", "desc": true }]
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "filterable": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 100 }
            ]
          },
          "mappings": []
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Drift Score" },
            "properties": [
              { "id": "custom.displayMode", "value": "color-background" },
              { "id": "custom.cellOptions", "value": { "type": "gauge", "showUnfilled": true } }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "sentinel_drift_score_gauge",
          "legendFormat": "{{provider}} / {{consumer}} / {{endpoint}}",
          "refId": "A",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Job": true,
              "Instance": true,
              "__name__": true
            },
            "indexByName": {},
            "renameByName": {
              "Value": "Drift Score",
              "provider": "Provider",
              "consumer": "Consumer",
              "endpoint": "Endpoint"
            }
          }
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 11 },
      "id": 3,
      "panels": [],
      "title": "Violation Timeline",
      "type": "row"
    },
    {
      "id": 4,
      "title": "Violations by Severity",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "options": {
        "legend": { "calcs": [], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "stacking": { "mode": "normal", "group": "A" },
            "fillOpacity": 80,
            "lineWidth": 0,
            "pointSize": 0,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "BREAKING" },
            "properties": [{ "id": "color", "value": { "fixed": "red" } }]
          },
          {
            "matcher": { "id": "byName", "options": "WARNING" },
            "properties": [{ "id": "color", "value": { "fixed": "yellow" } }]
          },
          {
            "matcher": { "id": "byName", "options": "ADDITIVE" },
            "properties": [{ "id": "color", "value": { "fixed": "blue" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum by (severity) (rate(sentinel_violations_total{severity=\"BREAKING\"}[5m]))",
          "legendFormat": "BREAKING",
          "refId": "A"
        },
        {
          "expr": "sum by (severity) (rate(sentinel_violations_total{severity=\"WARNING\"}[5m]))",
          "legendFormat": "WARNING",
          "refId": "B"
        },
        {
          "expr": "sum by (severity) (rate(sentinel_violations_total{severity=\"ADDITIVE\"}[5m]))",
          "legendFormat": "ADDITIVE",
          "refId": "C"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 },
      "id": 5,
      "panels": [],
      "title": "Gate Decisions",
      "type": "row"
    },
    {
      "id": 6,
      "title": "Promotion Gate Decisions",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 23 },
      "options": {
        "legend": { "calcs": [], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "stacking": { "mode": "normal", "group": "A" },
            "fillOpacity": 80,
            "lineWidth": 0,
            "pointSize": 0,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "allow" },
            "properties": [{ "id": "color", "value": { "fixed": "green" } }]
          },
          {
            "matcher": { "id": "byName", "options": "deny" },
            "properties": [{ "id": "color", "value": { "fixed": "red" } }]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum by (decision) (rate(sentinel_gate_decisions_total{decision=\"allow\"}[5m]))",
          "legendFormat": "allow",
          "refId": "A"
        },
        {
          "expr": "sum by (decision) (rate(sentinel_gate_decisions_total{decision=\"deny\"}[5m]))",
          "legendFormat": "deny",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 33 },
      "id": 7,
      "panels": [],
      "title": "Inference Latency",
      "type": "row"
    },
    {
      "id": 8,
      "title": "Inference Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 34 },
      "options": {
        "legend": { "calcs": [], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 0,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p99" },
            "properties": [
              { "id": "color", "value": { "fixed": "red" } },
              { "id": "custom.lineWidth", "value": 3 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "p95" },
            "properties": [
              { "id": "color", "value": { "fixed": "yellow" } },
              { "id": "custom.lineWidth", "value": 2 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "p50" },
            "properties": [
              { "id": "color", "value": { "fixed": "green" } },
              { "id": "custom.lineWidth", "value": 1 }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(sentinel_inference_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(sentinel_inference_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(sentinel_inference_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["contract-drift", "sentinel"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "label": "Data Source",
        "skipUrlSync": false
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h", "2h", "1d"],
    "time_options": ["5m", "15m", "1h", "6h", "12h", "24h", "2d", "7d", "30d"]
  },
  "timezone": "utc"
}
